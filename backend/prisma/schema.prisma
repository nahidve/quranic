generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =========================
 * ENUMS
 * =========================
 */
enum FavoriteType {
  QURAN
  HADITH
  DUA
}

enum TopicTargetType {
  QURAN
  HADITH
  DUA
}

/**
 * =========================
 * USER
 * =========================
 */
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  progress  Progress[]
  favorites Favorite[]
  notes     Note[]
}

/**
 * =========================
 * QURAN
 * =========================
 */
model QuranSurah {
  id          Int    @id
  name        String
  englishName String

  ayahs QuranAyah[]
}

model QuranAyah {
  id      String @id @default(cuid())
  surahId Int
  number  Int
  text    String
  juz     Int

  surah QuranSurah @relation(fields: [surahId], references: [id])
  notes Note[]

  @@index([surahId, number])
  @@index([juz])
}

/**
 * =========================
 * PROGRESS
 * =========================
 */
model Progress {
  id        String   @id @default(cuid())
  userId    String
  ayahId    String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/**
 * =========================
 * FAVORITES
 * =========================
 */
model Favorite {
  id        String       @id @default(cuid())
  userId    String
  type      FavoriteType
  refId     String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

/**
 * =========================
 * NOTES
 * =========================
 */
model Note {
  id        String   @id @default(cuid())
  userId    String
  ayahId    String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id])
  ayah QuranAyah? @relation(fields: [ayahId], references: [id])

  @@index([userId])
}

/**
 * =========================
 * HADITH
 * =========================
 */
model HadithBook {
  id      String   @id @default(cuid())
  name    String
  hadiths Hadith[]
}

model Hadith {
  id        String  @id @default(cuid())
  bookId    String
  chapter   String?
  number    Int?
  text      String
  reference String?

  book HadithBook @relation(fields: [bookId], references: [id])

  @@index([bookId])
}

/**
 * =========================
 * DUA
 * =========================
 */
model DuaCategory {
  id   String @id @default(cuid())
  name String
  duas Dua[]
}

model Dua {
  id         String @id @default(cuid())
  categoryId String
  title      String
  text       String

  category DuaCategory @relation(fields: [categoryId], references: [id])
}

/**
 * =========================
 * TOPICS
 * =========================
 */
model Topic {
  id   String @id @default(cuid())
  name String
  slug String @unique

  topicMaps TopicMap[]
}

model TopicMap {
  id      String          @id @default(cuid())
  topicId String
  type    TopicTargetType
  refId   String

  topic Topic @relation(fields: [topicId], references: [id])

  @@index([type, refId])
}
